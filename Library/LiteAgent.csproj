<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    
    <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
    <PackageId>LiteAgent</PackageId>
    <Version>0.1.9</Version>
    <RepositoryType>git</RepositoryType>
    <PackageRequireLicenseAcceptance>false</PackageRequireLicenseAcceptance>
    <Authors>Coquencio</Authors>
    <Description>A high-performance, token-efficient AI Agent tool-calling library for .NET. Replaces JSON with TOON for token savings.</Description>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageProjectUrl>https://github.com/Coquencio/LiteAgent</PackageProjectUrl>
    <RepositoryUrl>https://github.com/Coquencio/LiteAgent</RepositoryUrl>
    <PackageTags>AI;Agent;LLM;OpenAI;ToolCalling;TOON;Azure;Orchestration;Chaining;Agentic;FunctionCalling;Efficiency;DotNet;Gemini;Claude</PackageTags>
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Anthropic.SDK" Version="5.10.0" />
    <PackageReference Include="Azure.AI.OpenAI" Version="2.9.0-beta.1" />
    <PackageReference Include="Google.GenAI" Version="1.6.1" />
  </ItemGroup>

  <ItemGroup>
    <None Include="..\Docs\README.md" Pack="true" PackagePath="\" />
    <None Include="..\Docs\**\*" Pack="true" PackagePath="docs\" />
  </ItemGroup>

</Project>